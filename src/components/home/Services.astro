---
import Location from '@/assets/icons/location.svg';
import Calendar from '@/assets/icons/calendar.svg';
import Dollar from '@/assets/icons/dollar.svg';
import InfoCard from '@/components/InfoCard.astro';

interface Service {
  title: string;
  description: string;
  icon: typeof Location;
}

const services: Service[] = [
  {
    title: 'Selección de Destinos',
    description:
      'Descubre el destino perfecto que coincida con tus intereses y preferencias. Sea una escapada romántica, una aventura familiar o un viaje cultural, te ayudamos a encontrar el lugar ideal.',
    icon: Location,
  },
  {
    title: 'Diseño de Itinerarios',
    description:
      'Creamos un itinerario que se adapta a tus necesidades, teniendo en cuenta tus actividades preferidas y preferencias de alojamientos y transporte.',
    icon: Calendar,
  },
  {
    title: 'Gestión de Presupuesto',
    description:
      'Te ayudamos a mantenerte dentro de tu presupuesto eligiendo el mejor momento de compra, con desgloses transparentes de costes y consejos de gasto.',
    icon: Dollar,
  },
];
---

<section class="mx-auto max-w-7xl px-4 py-16">
  <h2 class="mb-4 text-4xl font-extrabold tracking-tight text-gray-800">
    Planificación integral de viajes
  </h2>
  <p class="mb-12 text-lg text-gray-600">
    Ofrecemos servicios de planificación integral de viajes para asegurar que tu
    viaje sea inolvidable sin que tengas que preocuparte por los detalles.
  </p>

  <div class="grid gap-6 md:grid-cols-3">
    {
      services.map(service => (
        <InfoCard
          icon={service.icon}
          title={service.title}
          description={service.description}
        />
      ))
    }
  </div>
</section>

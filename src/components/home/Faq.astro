---
import { HOME_FAQS as faqs } from '@/config/faqs';
import SectionHeading from '@/components/SectionHeading.astro';
---

<section id="faq" class="mx-auto max-w-7xl px-4 py-16 md:py-24">
  <SectionHeading
    eyebrow="Resolvemos tus dudas"
    title="Preguntas frecuentes"
    class="mb-12"
  />

  <div class="space-y-4">
    {
      faqs.map((faq, index) => (
        <details
          class="group cursor-pointer rounded-xl border-2 border-gray-200 bg-white p-6 transition-all duration-300 hover:border-[#12a3ed] hover:shadow-lg"
          open={index === 0}
        >
          <summary class="flex items-center justify-between select-none">
            <h3 class="text-lg font-semibold text-gray-900 transition-colors duration-300 group-open:text-[#12a3ed]">
              {faq.question}
            </h3>
            <span class="mt-1 ml-4 flex-shrink-0 text-2xl font-bold text-[#12a3ed] transition-all duration-300 group-open:hidden">
              +
            </span>
            <span class="mt-1 ml-4 hidden flex-shrink-0 text-2xl font-bold text-[#12a3ed] transition-all duration-300 group-open:block">
              −
            </span>
          </summary>

          <div class="mt-6 space-y-4 border-t-2 border-gray-100 pt-6 text-base leading-relaxed text-gray-700">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))
    }
  </div>
</section>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }

  details summary {
    list-style: none;
  }

  @media (max-width: 768px) {
    details summary {
      padding-right: 2rem;
    }
  }
</style>

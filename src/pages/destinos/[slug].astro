---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

import Layout from '@/layouts/Layout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import RelatedArticles from '@/components/blog/DestinationEntries.astro';
import DestinationCustomers from '@/components/destinations/DestinationCustomers.astro';
import Cta from '@/components/Cta.astro';
import {
  getCombinedSchema,
  getTouristDestinationSchema,
  getTouristTripSchema,
} from '@/config/schemas';
import Calendar from '@/assets/icons/calendar.svg';
import Clock from '@/assets/icons/clock.svg';
import Dollar from '@/assets/icons/dollar.svg';
import Location from '@/assets/icons/location.svg';

// Etiqueta de tipo de turismo para el schema TouristTrip, según la categoría
const TOURIST_TYPE_BY_CATEGORY: Record<string, string | undefined> = {
  cultural: 'Turismo cultural',
  playa: 'Turismo de playa',
  naturaleza: 'Turismo de naturaleza',
  ciudad: 'Escapada urbana',
  barco: 'Viaje en barco',
  sorpresa: 'Viaje sorpresa',
  destacados: undefined,
};

interface Props {
  destination: CollectionEntry<'destinations'>;
}

export async function getStaticPaths() {
  const destinations = await getCollection('destinations');
  return destinations.map(destination => ({
    params: { slug: destination.id.replace('.md', '') },
    props: {
      destination,
    },
  }));
}

const { destination } = Astro.props;

const title = `Viajar a ${destination.data.name} a tu Medida | Kilómetros por Explorar`;
const description = destination.data.shortDescription;
const pathname = Astro.url.pathname;

const isSurprise = destination.data.category === 'sorpresa';
const tripName = isSurprise
  ? destination.data.name
  : `Viaje a ${destination.data.name} a tu medida`;

const destinationSchema = getTouristDestinationSchema(
  destination.data.name,
  description,
  destination.data.image.src,
  destination.data.country,
  pathname
);
const tripSchema = getTouristTripSchema(
  tripName,
  destination.data.longDescription,
  pathname,
  destination.data.image.src,
  destination.data.country,
  TOURIST_TYPE_BY_CATEGORY[destination.data.category]
);
const schema = getCombinedSchema(destinationSchema, tripSchema);

const budgetLabel = `Desde ${new Intl.NumberFormat('es-ES').format(destination.data.budget)} €`;
const quickFacts = [
  {
    icon: Calendar,
    label: 'Mejor época',
    value: destination.data.bestSeason,
  },
  {
    icon: Clock,
    label: 'Duración ideal',
    value: destination.data.idealDuration,
  },
  { icon: Dollar, label: 'Presupuesto', value: budgetLabel },
  {
    icon: Location,
    label: 'Ruta clásica',
    value: destination.data.clasicRouteElements.join(' · '),
  },
];
---

<Layout
  title={title}
  description={description}
  schema={schema}
  image={destination.data.image}
  imageAlt={destination.data.imageAlt}
>
  <main id="main">
    <!-- Breadcrumbs -->
    <div class="mx-auto max-w-7xl px-4 pt-24 pb-4">
      <Breadcrumbs
        items={[
          { name: 'Inicio', href: '/' },
          { name: 'Destinos', href: '/destinos' },
          { name: destination.data.name },
        ]}
      />
    </div>

    <!-- Hero -->
    <section class="mx-auto max-w-7xl px-4">
      <h1 class="mb-4 text-3xl font-bold text-gray-800">
        {destination.data.name}
      </h1>
      <p class="mb-8 text-gray-600">{destination.data.longDescription}</p>
      <Image
        src={destination.data.image}
        alt={destination.data.imageAlt}
        class="h-[400px] w-full rounded-2xl object-cover md:h-[600px]"
        widths={[640, 1280, 1920]}
        sizes="(max-width: 1280px) 100vw, 1280px"
        loading="eager"
      />
    </section>

    <!-- Quick facts -->
    <section class="mx-auto max-w-7xl px-4 pt-8">
      <div
        class="flex flex-wrap overflow-hidden rounded-xl border border-gray-200 bg-white"
      >
        {
          quickFacts.map((fact, index) => (
            <div
              class:list={[
                'flex flex-1 basis-[220px] items-center gap-4 p-6',
                index > 0 && 'border-l border-gray-200',
              ]}
            >
              <span class="flex size-11 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <fact.icon class="size-5.5" />
              </span>
              <div>
                <div class="mb-1 text-xs font-extrabold tracking-[0.08em] text-gray-500 uppercase">
                  {fact.label}
                </div>
                <div class="text-lg font-bold text-gray-900">{fact.value}</div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <RelatedArticles destination={destination} />
    <DestinationCustomers destination={destination} />
  </main>
  <div class="mt-12">
    <Cta />
  </div>
</Layout>

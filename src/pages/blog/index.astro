---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import PageTitle from '@/components/PageTitle.astro';
import BlogCard from '@/components/blog/BlogEntryCard.astro';
import { getCombinedSchema, getWebPageSchema } from '@/config/schemas';

const title = 'Blog | Kilómetros por Explorar';
const description =
  'Consejos de viaje, itinerarios y guías de destinos para planificar tu próxima aventura. Lee el blog de Kilómetros por Explorar y viaja mejor.';
const pathname = Astro.url.pathname;
const pageSchema = getWebPageSchema(title, description, pathname);
const schema = getCombinedSchema(pageSchema);

const posts: CollectionEntry<'blog'>[] = await getCollection('blog');
const sortedPosts: CollectionEntry<'blog'>[] = posts.sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title={title} description={description} schema={schema}>
  <main
    id="main"
    class="animate-fade-in-up mx-auto max-w-7xl px-4 pt-28 pb-20 md:pt-36"
  >
    <PageTitle
      eyebrow="Nuestro blog"
      title="Consejos, guías e itinerarios para tu próximo viaje"
      class="mb-8 lg:mb-12"
    />

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        sortedPosts.map((post, index) => (
          <BlogCard
            post={post}
            loading={index < 3 ? 'eager' : 'lazy'}
            priority={index === 0}
          />
        ))
      }
    </div>
  </main>
</Layout>

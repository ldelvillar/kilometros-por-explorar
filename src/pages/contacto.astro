---
import Layout from '@/layouts/Layout.astro';
import ContactForm from '@/components/ContactForm.astro';
import PageTitle from '@/components/PageTitle.astro';
import Envelope from '@/assets/icons/envelope.svg';
import Phone from '@/assets/icons/phone.svg';
import Location from '@/assets/icons/location.svg';
import Clock from '@/assets/icons/clock.svg';
import Instagram from '@/assets/icons/instagram.svg';
import { getWebPageSchema, getCombinedSchema } from '@/config/schemas';
import { SITE_CONFIG } from '@/config/site';

const title = 'Contacto | Kilómetros por Explorar';
const description =
  'Ponte en contacto con nosotros para planificar tu próximo viaje. Estamos aquí para ayudarte a hacer realidad tu aventura soñada.';
const pathname = '/contact';

// Schema configuration
const pageSchema = getWebPageSchema(title, description, pathname);
const schema = getCombinedSchema(pageSchema);

const { company, social } = SITE_CONFIG;
const chipClass =
  'flex size-11 shrink-0 items-center justify-center rounded-lg bg-white/20';
const labelClass = 'mb-0.5 text-sm tracking-[0.08em] text-white/75 uppercase';
---

<Layout title={title} description={description} schema={schema}>
  <main id="main" class="animate-fade-in-up">
    <!-- Title band -->
    <section
      class="border-b border-gray-300 bg-gray-50 px-4 pt-28 pb-16 text-center md:pt-36"
    >
      <PageTitle eyebrow="Contacto" title="Empecemos a planificar" />
      <p
        class="mx-auto mt-4 max-w-[540px] text-lg leading-relaxed text-gray-600"
      >
        Estamos aquí para ayudarte a planificar tu viaje ideal. Completa el
        formulario a continuación o contáctanos a través de los métodos
        indicados y nos pondremos en contacto contigo lo antes posible.
      </p>
    </section>

    <!-- Panel + form -->
    <section class="px-4 pt-16 pb-24">
      <div
        class="mx-auto grid max-w-7xl grid-cols-1 items-stretch gap-8 lg:grid-cols-[3fr_2fr]"
      >
        <!-- Contact Form -->
        <div
          class="rounded-2xl border border-gray-300 bg-white p-6 shadow-md sm:p-12"
        >
          <h2 class="mb-6 text-2xl font-bold text-gray-900">
            Solicitud de información
          </h2>
          <ContactForm />
        </div>

        <!-- Contact Information -->
        <div
          class="flex flex-col gap-8 rounded-2xl bg-primary p-6 text-white sm:p-10"
        >
          <div>
            <h2 class="mb-2 text-2xl font-bold">Información de contacto</h2>
            <p class="leading-relaxed text-white/85">
              Sin comisiones, sin intermediarios. Somos nosotros quienes te
              respondemos.
            </p>
          </div>

          <div class="flex flex-col gap-6">
            <div class="flex items-start gap-4">
              <div class={chipClass}>
                <Envelope class="size-5" />
              </div>
              <div class="min-w-0">
                <p class={labelClass}>Email</p>
                <a
                  href={'mailto:' + company.email}
                  class="text-base leading-relaxed hover:underline"
                >
                  {company.email}
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class={chipClass}>
                <Phone class="size-5" />
              </div>
              <div class="min-w-0">
                <p class={labelClass}>Teléfonos</p>
                <p class="text-base leading-relaxed">
                  <a
                    href={'tel:' + company.phone.replace(/\s/g, '')}
                    class="hover:underline">{company.phone}</a
                  ><br />
                  <a
                    href={'tel:' + company.phone2.replace(/\s/g, '')}
                    class="hover:underline">{company.phone2}</a
                  >
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class={chipClass}>
                <Instagram class="size-5" />
              </div>
              <div class="min-w-0">
                <p class={labelClass}>Instagram</p>
                <a
                  href={social.instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-base leading-relaxed hover:underline"
                >
                  @kilometrosporexplorar
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class={chipClass}>
                <Clock class="size-5" />
              </div>
              <div class="min-w-0">
                <p class={labelClass}>Horario</p>
                <p class="text-base leading-relaxed">
                  Lun–Vie 9:00–18:00<br />
                  Sáb 10:00–14:00 · Dom cerrado
                </p>
              </div>
            </div>
          </div>

          <div
            class="mt-auto flex items-center gap-3 border-t border-white/25 pt-6 text-white/95"
          >
            <Location class="size-5" />
            <span>{company.address}</span>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

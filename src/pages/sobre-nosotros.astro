---
import { Image } from 'astro:assets';
import Layout from '@/layouts/Layout.astro';
import Timeline from '@/components/Timeline.astro';
import Cta from '@/components/Cta.astro';
import InfoCard from '@/components/InfoCard.astro';
import PageTitle from '@/components/PageTitle.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { getWebPageSchema, getCombinedSchema } from '@/config/schemas';
import { SITE_CONFIG } from '@/config/site';
import couple from '@/assets/images/team/couple.webp';
import lucas from '@/assets/images/team/lucas.webp';
import lucia from '@/assets/images/team/lucia.webp';
import User from '@/assets/icons/user.svg';
import Magnifier from '@/assets/icons/magnifier.svg';
import Dollar from '@/assets/icons/dollar.svg';
import Instagram from '@/assets/icons/instagram.svg';
import TikTok from '@/assets/icons/tiktok.svg';

const title = 'Sobre Nosotros | Kilómetros por Explorar';
const description =
  'Conoce al equipo detrás de Kilómetros por explorar, una pareja apasionada por crear experiencias de viaje inolvidables. Descubre nuestra historia y filosofía.';
const pathname = '/sobre-nosotros';

// Schema configuration
const pageSchema = getWebPageSchema(title, description, pathname);
const schema = getCombinedSchema(pageSchema);

const stats = [
  { value: '28', label: 'Países explorados' },
  { value: '+2', label: 'Años de experiencia' },
  { value: '+100', label: 'Viajes organizados' },
  { value: '5/5', label: 'Valoración de viajeros' },
];

const values = [
  {
    icon: User,
    title: 'Cercano',
    description:
      'Creemos que cada experiencia es única. Por eso, nos encargamos de adaptarla a tus preferencias y necesidades.',
  },
  {
    icon: Magnifier,
    title: 'Experto',
    description:
      'Recomendamos destinos y experiencias que hemos visitado en persona. Y si no conocemos un destino, te lo decimos.',
  },
  {
    icon: Dollar,
    title: 'Transparente',
    description:
      'Tú reservas: sin comisiones ocultas ni paquetes cerrados. Todo claro desde el principio.',
  },
];

const team = [
  {
    image: lucas,
    name: 'Lucas del Villar',
    role: 'Co-Fundador & CEO',
    bio: 'Apasionado de los mapas y la logística. Diseña las rutas para que no pierdas ni un minuto — ni un rincón.',
  },
  {
    image: lucia,
    name: 'Lucía Ruiz',
    role: 'Co-Fundadora & CEO',
    bio: 'Cazadora de lugares con encanto. Elige los sitios, sabores y experiencias que hacen único cada viaje.',
  },
];

const socials = [
  { icon: Instagram, name: 'Instagram', href: SITE_CONFIG.social.instagram },
  { icon: TikTok, name: 'TikTok', href: SITE_CONFIG.social.tiktok },
];
---

<Layout title={title} description={description} schema={schema}>
  <main id="main" class="animate-fade-in-up">
    <section
      class="mx-auto max-w-3xl px-4 pt-28 pb-16 text-center md:pt-36 md:pb-20"
    >
      <PageTitle
        eyebrow="Hecho a tu medida"
        title="Sobre Nosotros"
        class="mb-[22px]"
      />
      <p class="mx-auto max-w-[600px] text-lg text-gray-600">
        Una pareja apasionada por crear experiencias de viaje inolvidables — y
        el equipo detrás de cada itinerario hecho a medida.
      </p>
    </section>

    <section class="bg-gray-50">
      <div
        class="mx-auto grid max-w-7xl gap-10 px-4 py-16 md:grid-cols-2 md:items-center md:gap-16 md:py-24"
      >
        <Image
          src={couple}
          alt="Foto de los fundadores de Kilómetros por explorar"
          class="aspect-square w-full rounded-2xl object-cover"
          widths={[400, 600, 800]}
          sizes="(max-width: 768px) 100vw, 480px"
          loading="eager"
        />
        <div>
          <SectionHeading
            eyebrow="Nuestra Historia"
            title="De dos mochileros a planificadores de viajes"
            class="mb-4"
          />
          <p class="max-w-[540px] text-lg leading-relaxed text-gray-600">
            Somos una pareja de viajeros que decidió convertir su pasión por
            explorar el mundo en un estilo de vida. Desde nuestras primeras
            aventuras juntos, supimos que queríamos compartir nuestras
            experiencias y ayudar a otros a descubrir la belleza de viajar. Así
            es cómo nació Kilómetros por Explorar.
          </p>
        </div>
      </div>
    </section>

    <section class="border-y border-gray-100 bg-gray-50">
      <div
        class="mx-auto grid max-w-7xl grid-cols-2 gap-8 px-4 py-12 md:grid-cols-4 md:py-14"
      >
        {
          stats.map(stat => (
            <div class="text-center">
              <span class="mb-1 block bg-gradient-to-b from-blue-700 to-primary bg-clip-text font-blimone text-4xl font-bold text-transparent md:text-5xl">
                {stat.value}
              </span>
              <p class="text-sm text-gray-600 md:text-base">{stat.label}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-16 md:py-24">
      <div class="mb-10 max-w-[620px] md:mb-12">
        <SectionHeading
          eyebrow="Nuestra Filosofía"
          title="Cercano, experto y transparente"
        />
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {
          values.map(value => (
            <InfoCard
              icon={value.icon}
              title={value.title}
              description={value.description}
            />
          ))
        }
      </div>
    </section>

    <section class="bg-gray-50 px-4 py-16 md:py-24">
      <SectionHeading
        align="center"
        eyebrow="Nuestro viaje"
        title="Cómo llegamos hasta aquí"
        class="mb-14"
      />
      <Timeline />
    </section>

    <section class="mx-auto max-w-4xl px-4 py-16 md:py-24">
      <div class="mx-auto mb-10 max-w-[620px] text-center md:mb-12">
        <SectionHeading
          align="center"
          eyebrow="Conoce al equipo"
          title="Las personas detrás de tu viaje"
        />
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        {
          team.map(member => (
            <div class="flex flex-col items-center rounded-2xl border border-gray-200 bg-white p-8 text-center">
              <Image
                src={member.image}
                alt={`Foto de ${member.name}`}
                class="size-32 rounded-full object-cover md:size-36"
                width={144}
                height={144}
                loading="lazy"
              />
              <h3 class="mt-4 text-xl font-semibold text-gray-900">
                {member.name}
              </h3>
              <p class="mt-1 text-sm font-semibold text-primary">
                {member.role}
              </p>
              <p class="mt-3 max-w-[280px] text-gray-600">{member.bio}</p>
              <div class="mt-6 flex gap-3">
                {socials.map(social => (
                  <a
                    href={social.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={social.name}
                    class="inline-flex size-10 items-center justify-center rounded-full border border-gray-200 text-gray-600 transition-all duration-200 hover:border-primary hover:bg-primary/10 hover:text-primary"
                  >
                    <social.icon class="size-5" />
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <Cta />
  </main>
</Layout>

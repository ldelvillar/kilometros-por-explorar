---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/home/Hero.astro';
import Services from '@/components/home/Services.astro';
import PopularDestinations from '@/components/home/PopularDestinations.astro';
import Blog from '@/components/home/Blog.astro';
import Customers from '@/components/home/Customers.astro';
import Faq from '@/components/home/Faq.astro';
import Contact from '@/components/home/Contact.astro';

import {
  getCombinedSchema,
  getWebPageSchema,
  getFAQSchema,
} from '@/config/schemas';
import { HOME_FAQS } from '@/config/faqs';

const title = 'Planificación Profesional de Viajes | Kilómetros por Explorar';
const description =
  'Planificamos tu viaje de forma profesional y económica. Descubre destinos, itinerarios personalizados a medida y consejos de viaje con nosotros.';
const pathname = Astro.url.pathname;

const pageSchema = getWebPageSchema(title, description, pathname);
const faqSchema = getFAQSchema(HOME_FAQS);
const schema = getCombinedSchema(pageSchema, faqSchema);
---

<Layout title={title} description={description} schema={schema}>
  <main id="main">
    <Hero />
    <Services />
    <PopularDestinations />
    <Customers />
    <Blog />
    <Faq />
    <Contact />
  </main>
</Layout>

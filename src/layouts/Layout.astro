---
import type { ImageMetadata } from 'astro';
import MetaTags from '@/components/MetaTags.astro';
import Header from '@/components/layout/Header.astro';
import Chatbot from '@/components/layout/Chatbot.tsx';
import CookieBanner from '@/components/CookieBanner.tsx';
import Footer from '@/components/layout/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  schema?: object;
  image?: string | ImageMetadata;
  imageAlt?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
}

const {
  title,
  description,
  schema,
  image,
  imageAlt,
  ogType,
  publishedTime,
  modifiedTime,
  author,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/images/brand/logo.png" />
    <MetaTags
      title={title}
      description={description}
      schema={schema}
      image={image}
      imageAlt={imageAlt}
      ogType={ogType}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
    />
  </head>
  <body class="font-display">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:rounded-lg focus:bg-primary focus:px-4 focus:py-2 focus:text-white focus:outline-none"
    >
      Saltar al contenido
    </a>
    <Header />
    <slot />
    <CookieBanner client:idle />
    <Chatbot client:idle />
    <Footer />
  </body>
</html>

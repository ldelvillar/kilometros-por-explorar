{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(pnpm lint *)",
      "Bash(pnpm build *)",
      "Bash(pnpm tsc *)",
      "PowerShell(pnpm lint *)",
      "PowerShell(pnpm build *)",
      "PowerShell(pnpm tsc *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$data = $input | ConvertFrom-Json; $f = $data.tool_input.file_path; if ($f) { pnpm exec prettier --write --ignore-unknown $f 2>$null }",
            "shell": "powershell",
            "statusMessage": "Formatting..."
          }
        ]
      }
    ]
  }
}
